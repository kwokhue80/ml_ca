03cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003erepo_url = f\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ehttps://{git_token}@github.com/{GIT_USERNAME}/{REPO_NAME}.git\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eprint(\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eCloning private repository...\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e)\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e!git clone --depth 1 {repo_url} # \u0026#39;--depth 1\u0026#39; clones fast by only pulling the latest commit\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e# 4. Point to your exact training directory\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003edataset_dir = os.path.join(\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e/content\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, REPO_NAME, IMAGE_FOL