oss: 0.2391\\n\",","            \"Epoch 8/10\\n\",","            \"\\u001b[1m6/6\\u001b[0m \\u001b[32m━━━━━━━━━━━━━━━━━━━━\\u001b[0m\\u001b[37m\\u001b[0m \\u001b[1m22s\\u001b[0m 3s/step - accuracy: 0.9432 - loss: 0.2057 - val_accuracy: 0.9545 - val_loss: 0.1600\\n\",","            \"Epoch 9/10\\n\",","            \"\\u001b[1m6/6\\u001b[0m \\u001b[32m━━━━━━━━━━━━━━━━━━━━\\u001b[0m\\u001b[37m\\u001b[0m \\u001b[1m38s\\u001b[0m 3s/step - accuracy: 0.9318 - loss: 0.2110 - val_accuracy: 0.9091 - val_loss: 0.1871\\n\",","            \"Epoch 10/10\\n\",","            \"\\u001b[1m6/6\\u001b[0m \\u001b[32m━━━━━━━━━━━━━━━━━━━━\\u001b[0m\\u001b[37m\\u001b[0m \\u001b[1m20s\\u001b[0m 4s/step - accuracy: 0.9489 - loss: 0.1679 - val_accuracy: 0.8864 - val_loss: 0.1864\\n\"","          ]","        }","      ],","      \"source\": [","        \"# =========================================\\n\",","        \"# 7. Train the model\\n\",","        \"# =========================================\\n\",","        \"EPOCHS = 10\\n\",","        \"history = model.fit(\\n\",","        \"    train_generator,\\n\",","        \"    validation_data=val_generator,\\n\",","        \"    epochs=EPOCHS\\n\",","        \")\"","      ]","    },","    {","      \"cell_type\": \"code\",","      \"execution_count\": 17,","      \"id\": \"d726a3ad\",","      \"metadata\": {","        \"id\": \"d726a3ad\",","        \"outputId\": \"4fffafb8-07dc-48ac-99d0-ead06b68c410\",","        \"colab\": {","          \"base_uri\": \"https://localhost:8080/\",","          \"height\": 487","        }","      },","      \"outputs\": [","        {","          \"output_type\": \"display_data\",","          \"data\": {","            \"text/plain\": [","              \"\u003cFigure size 800x500 with 1 Axes\u003e\"","            ],","            \"image/png\": \"\\n\"","          },","          \"metadata\": {}","        }","      ],","      \"source\": [","        \"# =========================================\\n\",","        \"# 8.